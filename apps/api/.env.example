PORT=8095
# API bind address — 127.0.0.1 in production (nginx reverse proxy); 0.0.0.0 for local dev
# BIND_HOST=127.0.0.1
POSTGRES_USER=devuko
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=devuko_crm
DATABASE_URL=postgresql://devuko:change-me-postgres@127.0.0.1:5440/devuko_crm
JWT_SECRET=change-me-devuko-crm
# JWT lifetime in seconds (default 28800 = 8h dev; production API default 7200 = 2h if unset).
JWT_EXPIRES_IN=28800
# Allow legacy password-only login in production (default: disabled — use OTP).
# AUTH_PASSWORD_LOGIN=true
# Return JWT in OTP verify JSON body (default: cookie only in production).
# AUTH_RETURN_TOKEN=true
# Disable platform/site deploy from CRM UI (recommended in production — use CI/make deploy).
# DEVUKO_CRM_DEPLOY_ENABLED=false
# Optional high-risk overlay: docker-compose.deploy.yml mounts docker.sock for UI deploy/metrics.
DEVUKO_PROXY_SECRET=change-me-proxy-secret
# Local dev only — omit in production (admins via platform/bin/crm-add-admin.sh).
DEV_ALLOW_WEAK_JWT=true
CRM_ADMIN_EMAIL=admin@devuko.ru
# Production CORS origins (comma-separated). If unset, uses VITE_PUBLIC_URL when set.
# CORS_ORIGINS=https://crm.devuko.ru
# VITE_PUBLIC_URL=https://crm.devuko.ru
# Email OTP login (SMTP). Set AUTH_OTP_ECHO=true in dev to log codes to API console.
# Sender: noreply@devuko.ru (default). support@devuko.ru is used for @mail.ru recipients.
AUTH_SMTP_HOST=mail.hosting.reg.ru
AUTH_SMTP_PORT=465
AUTH_SMTP_USER=noreply@devuko.ru
AUTH_SMTP_PASS=
AUTH_EMAIL_FROM=Devuko CRM <noreply@devuko.ru>
AUTH_SMTP_USER_SUPPORT=support@devuko.ru
AUTH_EMAIL_FROM_SUPPORT=Devuko CRM <support@devuko.ru>
AUTH_OTP_ECHO=false
# Repo root — auto-detected from code; override only if needed
# PLATFORM_REPO_ROOT=/home/USER/sites/crm.devuko.ru/repo
SELFPACT_WORKSPACE_DOMAIN=selfpact.ru
SELFPACT_WORKSPACE_API_BASE=http://127.0.0.1:8081
SELFPACT_REPO_URL=git@github.com:SadForeverAlone/selfpact.git
# Dev-only: localhost ports allowed by workspace SSRF checks (comma-separated)
# WORKSPACE_DEV_PORTS=8080,8081,8088,8095,3000

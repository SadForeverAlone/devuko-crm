{
  "name": "@devuko/crm-api",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=25.0.0"
  },
  "scripts": {
    "start:dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "crm:add-admin": "node scripts/crm-add-admin.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",

    "test:db": "CRM_DB_INTEGRATION=true vitest run --config vitest.db.config.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.1.1",
    "@fastify/helmet": "^13.1.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.5.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.4.2",
    "nodemailer": "^9.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.28",
    "@swc/core": "^1.15.43",
    "@types/nodemailer": "^6.4.24",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "eslint": "^9.39.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.64.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.2.7"
  }
